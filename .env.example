 # ============================================
 # 智善TIC人才测评系统 - 环境变量配置
 # ============================================
 # 复制此文件为 .env 并填入实际值
 # cp .env.example .env
 # ============================================
 
 # Django 密钥（必填！生产环境务必修改）
 # 生成方法：python -c "import secrets; print(secrets.token_urlsafe(50))"
 DJANGO_SECRET_KEY=your-secret-key-here-change-me
 
 # Django 调试模式（生产环境请设为 False）
 DJANGO_DEBUG=False
 
 # 允许访问的域名（逗号分隔）
 DJANGO_ALLOWED_HOSTS=.zeabur.app,localhost,127.0.0.1,your-domain.com
 
 # CSRF 信任来源（逗号分隔）
 DJANGO_CSRF_TRUSTED_ORIGINS=https://*.zeabur.app,http://localhost:8000,https://your-domain.com
 
 # PostgreSQL 密码（可选，默认 tic123456）
 POSTGRES_PASSWORD=your-strong-password-here
 
 
 # HTTPS 重定向（有域名和证书时设为 True）
 DJANGO_SSL_REDIRECT=False
 # 服务端口（可选，默认 8000）
 PORT=8000
